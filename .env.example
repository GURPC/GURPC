# ─── Required ────────────────────────────────────────────────────────
# Supabase project credentials (get from: https://supabase.com/dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Optional ────────────────────────────────────────────────────────
# Set to "github-pages" to enable static export with basePath for GitHub Pages deployment.
# Leave unset for standard Next.js deployment (Vercel, self-hosted).
# DEPLOY_TARGET=github-pages
